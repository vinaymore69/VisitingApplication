<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:backgroundTint="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Main container matching the style of login/signup -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="100dp"
            android:padding="20dp"
            android:orientation="vertical">

            <!-- App Logo -->
            <ImageView
                android:layout_width="400dp"
                android:layout_height="180dp"
                android:src="@drawable/vplogo"
                android:layout_gravity="center"
                android:layout_marginBottom="80dp" />

            <!-- Email Input Field -->
            <EditText
                android:id="@+id/reset_email"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:ems="12"
                android:hint="Enter your Email"
                android:inputType="textEmailAddress"
                android:textSize="20sp"
                android:tooltipText="Email ID"
                android:textColor="@color/black"
                android:textColorHint="#68BB59"
                android:hapticFeedbackEnabled="true" />

            <!-- New Password Input Field -->
            <EditText
                android:id="@+id/new_password"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:ems="12"
                android:hint="New Password"
                android:inputType="textPassword"
                android:textSize="20sp"
                android:tooltipText="New Password"
                android:layout_marginTop="20dp"
                android:textColor="@color/black"
                android:textColorHint="#68BB59"
                android:hapticFeedbackEnabled="true" />

            <!-- Confirm New Password Input Field -->
            <EditText
                android:id="@+id/confirm_password"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:ems="12"
                android:hint="Confirm New Password"
                android:inputType="textPassword"
                android:textSize="20sp"
                android:tooltipText="Confirm New Password"
                android:layout_marginTop="20dp"
                android:textColor="@color/black"
                android:textColorHint="#68BB59"
                android:hapticFeedbackEnabled="true" />

            <!-- Reset Password Button -->
            <Button
                android:id="@+id/reset_button"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:text="Reset Password"
                android:textSize="18sp"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"
                android:backgroundTint="#116940"
                app:cornerRadius="30dp"
                android:paddingRight="20dp"
                android:paddingLeft="20dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:hapticFeedbackEnabled="true"
                android:textColor="@color/white" />

            <!-- Redirect Options -->
            <TextView
                android:id="@+id/redirect_to_login"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Remembered your password? Login"
                android:textSize="15sp"
                android:layout_marginTop="10dp"
                android:textColor="#4286F5"
                android:layout_gravity="center" />

            <TextView
                android:id="@+id/redirect_to_signup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Not registered yet? Sign Up"
                android:textSize="15sp"
                android:layout_marginTop="10dp"
                android:textColor="#4286F5"
                android:layout_gravity="center" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
