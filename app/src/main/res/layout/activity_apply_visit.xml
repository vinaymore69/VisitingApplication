<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/applyVisitScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:backgroundTint="@color/white"
    tools:context=".ApplyVisitActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Container similar to login/signup pages -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:padding="20dp"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Logo Image (similar style to login/signup pages) -->
            <ImageView
                android:layout_width="400dp"
                android:layout_height="180dp"
                android:src="@drawable/vplogo"
                android:layout_gravity="center"
                android:layout_marginBottom="0dp" />

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Apply For Visit"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="30dp"
                android:textColor="@color/black"
                />

            <!-- Name Field -->
            <EditText
                android:id="@+id/apply_name"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:hint="Name"
                android:inputType="textPersonName"
                android:padding="10dp"
                android:textSize="18sp"
                android:textColor="@color/black"
                android:textColorHint="#68BB59"
                />

            <!-- Email Field -->
            <EditText
                android:id="@+id/apply_email"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:hint="Email"
                android:inputType="textEmailAddress"
                android:padding="10dp"
                android:layout_marginTop="15dp"
                android:textSize="18sp"
                android:textColorHint="#68BB59"
                />

            <!-- Phone Field -->
            <EditText
                android:id="@+id/apply_phone"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:hint="Phone Number"
                android:inputType="phone"
                android:padding="10dp"
                android:layout_marginTop="15dp"
                android:textSize="18sp"
                android:textColorHint="#68BB59"/>

            <!-- Purpose Field -->
            <EditText
                android:id="@+id/apply_purpose"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:hint="Purpose"
                android:inputType="text"
                android:padding="10dp"
                android:layout_marginTop="15dp"
                android:textSize="18sp"
                android:textColorHint="#68BB59"/>

            <!-- Date Field -->
            <EditText
                android:id="@+id/apply_date"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:hint="Date (YYYY-MM-DD)"
                android:inputType="date"
                android:padding="10dp"
                android:layout_marginTop="15dp"
                android:textSize="18sp"
                android:textColorHint="#68BB59"/>

            <!-- Time Field -->
            <EditText
                android:id="@+id/apply_time"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:hint="Time (HH:MM)"
                android:inputType="time"
                android:padding="10dp"
                android:layout_marginTop="15dp"
                android:textSize="18sp"
                android:textColorHint="#68BB59"/>

            <!-- Apply Visit Button -->
            <Button
                android:id="@+id/apply_visit_button"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:text="Submit Request"
                android:textSize="18sp"
                android:layout_marginTop="30dp"
                android:backgroundTint="#116940"
                app:cornerRadius="30dp"
                android:padding="10dp"
                android:textColor="@color/white"
                android:textColorHint="#68BB59"
                android:layout_marginBottom="400dp"
                />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
